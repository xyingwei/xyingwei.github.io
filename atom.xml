ne&#34;&gt;&amp;#125;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&amp;#x2F;&amp;#x2F; 创建对象&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;let c1 &amp;#x3D; new City(&amp;#39;p城&amp;#39;,5);&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;console.log(c1.cname);&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;c1.about();&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;
